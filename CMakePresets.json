{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "linux-debug",
      "inherits": "base",
      "displayName": "Linux Debug (system Qt6 + OCCT)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-release",
      "inherits": "base",
      "displayName": "Linux Release (system Qt6 + OCCT)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-vcpkg-debug",
      "inherits": "linux-debug",
      "displayName": "Linux Debug (vcpkg manifest)",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "linux-qt68-debug",
      "inherits": "linux-debug",
      "displayName": "Linux Debug (Qt 6.8 in ~/Qt + system OCCT)",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{HOME}/Qt/6.8.3/gcc_64"
      }
    },
    {
      "name": "linux-qt68-release",
      "inherits": "linux-release",
      "displayName": "Linux Release (Qt 6.8 in ~/Qt + system OCCT)",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{HOME}/Qt/6.8.3/gcc_64"
      }
    },
    {
      "name": "windows-msvc-debug",
      "inherits": "base",
      "displayName": "Windows MSVC Debug (vcpkg manifest)",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-msvc-release",
      "inherits": "windows-msvc-debug",
      "displayName": "Windows MSVC Release (vcpkg manifest)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    { "name": "linux-debug",   "configurePreset": "linux-debug" },
    { "name": "linux-release", "configurePreset": "linux-release" },
    { "name": "linux-vcpkg-debug", "configurePreset": "linux-vcpkg-debug" },
    { "name": "linux-qt68-debug",   "configurePreset": "linux-qt68-debug" },
    { "name": "linux-qt68-release", "configurePreset": "linux-qt68-release" },
    { "name": "windows-msvc-debug",   "configurePreset": "windows-msvc-debug",   "configuration": "Debug" },
    { "name": "windows-msvc-release", "configurePreset": "windows-msvc-release", "configuration": "RelWithDebInfo" }
  ],
  "testPresets": [
    { "name": "linux-debug",   "configurePreset": "linux-debug",   "output": { "outputOnFailure": true } },
    { "name": "linux-release", "configurePreset": "linux-release", "output": { "outputOnFailure": true } },
    { "name": "linux-qt68-debug",   "configurePreset": "linux-qt68-debug",   "output": { "outputOnFailure": true } },
    { "name": "linux-qt68-release", "configurePreset": "linux-qt68-release", "output": { "outputOnFailure": true } }
  ]
}
